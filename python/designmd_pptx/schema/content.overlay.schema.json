          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "body": { "type": "string" }
            }
          }
        },
        "axes": {
          "type": "object",
          "properties": {
            "x": { "type": "string" },
            "y": { "type": "string" }
          }
        },
        "notes": { "type": "string" }
      }
    },
    "team": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "members": {
          "type": "array",
          "minItems": 2,
          "maxItems": 4,
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string" },
              "blurb": { "type": "string" }
            }
          }
        },
        "notes": { "type": "string" }
      }
