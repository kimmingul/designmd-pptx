    "logo_strip": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "logos": {
          "type": "array",
          "minItems": 2,
          "maxItems": 6,
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "properties": {
                  "label": { "type": "string" },
                  "src": { "type": "string" },
                  "alt": { "type": "string" }
                }
