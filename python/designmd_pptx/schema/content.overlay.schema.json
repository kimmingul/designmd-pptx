          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {
            "type": "object",
            "properties": {
              "value": { "type": ["string", "number"] },
              "label": { "type": "string" },
              "chip": { "type": "string" },
              "watch": { "type": "boolean" }
            }
          }
        }
      }
    },
    "kpi_3": { "$ref": "#/properties/kpi_row" },
    "kpi_dashboard_grid": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "notes": { "type": "string" },
        "kpis": {
          "type": "array",
          "minItems": 4,
          "maxItems": 8,
          "items": {
            "type": "object",
            "properties": {
              "value": { "type": ["string", "number"] },
              "label": { "type": "string" },
              "chip": { "type": "string" },
              "watch": { "type": "boolean" }
            }
          }
        }
      }
    },
