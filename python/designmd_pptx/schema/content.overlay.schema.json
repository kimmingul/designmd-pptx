        "quadrants": {
          "type": "array",
          "maxItems": 4,
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "body": { "type": "string" },
              "tag": { "type": "string" },
              "chip": { "type": "string" }
            }
          }
        }
      }
