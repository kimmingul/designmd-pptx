      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "notes": { "type": "string" },
        "levels": {
          "type": "array",
          "minItems": 3,
          "maxItems": 5,
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "properties": {
                  "label": { "type": "string" },
                  "title": { "type": "string" },
                  "detail": { "type": "string" },
                  "body": { "type": "string" }
                }
              }
            ]
          }
        },
        "steps": { "$ref": "#/properties/pyramid_levels/properties/levels" }
