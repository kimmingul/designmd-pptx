          "type": "array",
          "minItems": 2,
          "maxItems": 3,
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "price": { "type": ["string", "number"] },
              "period": { "type": "string" },
              "features": { "type": "array", "maxItems": 5, "items": { "type": "string" } },
              "highlight": { "type": "boolean" }
            }
          }
        },
        "notes": { "type": "string" }
