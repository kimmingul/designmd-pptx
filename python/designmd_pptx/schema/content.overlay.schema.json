    "process": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "notes": { "type": "string" },
        "steps": {
          "type": "array",
          "minItems": 2,
          "maxItems": 5,
          "items": {
            "oneOf": [
              { "type": "string" },
