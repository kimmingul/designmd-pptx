    "appendix_table": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "headers": { "type": "array", "maxItems": 8, "items": { "type": "string" } },
        "rows": {
          "type": "array",
          "maxItems": 14,
          "items": { "type": "array", "items": { "type": "string" } }
        },
        "notes": { "type": "string" }
      }
    }
